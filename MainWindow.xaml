<Window x:Class="PinBubble.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="64" Height="64"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Deactivated="Window_Deactivated"
        MouseLeftButtonDown="Root_MouseLeftButtonDown"
        MouseLeftButtonUp="Root_MouseLeftButtonUp"
        MouseMove="Root_MouseMove">

  <Grid>
    <!-- Pinned icon -->
    <Border x:Name="Pin"
            Width="52" Height="52"
            CornerRadius="26"
            Background="#FF2E2E2E"
            BorderBrush="#55FFFFFF"
            BorderThickness="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
      <TextBlock Text="🔑"
                 Foreground="White"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" Cursor="Hand"/>
    </Border>

    <!-- Expanded bubbles -->
    <Canvas x:Name="BubblesHost" Visibility="Collapsed" IsHitTestVisible="True">
      <!-- Buttons created in code-behind -->
    </Canvas>

    <Grid.ContextMenu>
      <ContextMenu>
        <MenuItem Header="Open text.text in VS Code" Click="OpenInVsCode_Click"/>
        <MenuItem Header="Open text.text in Notepad" Click="OpenInNotepad_Click"/>
        <Separator/>
        <MenuItem Header="Reload" Click="Reload_Click"/>
        <MenuItem Header="Exit" Click="Exit_Click"/>
      </ContextMenu>
    </Grid.ContextMenu>
  </Grid>
</Window>
