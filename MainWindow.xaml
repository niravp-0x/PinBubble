<Window x:Class="PinBubble.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="64" Height="64"
        Icon="Assets/pin.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        Deactivated="Window_Deactivated"
        StateChanged="Window_StateChanged"
        MouseLeftButtonDown="Root_MouseLeftButtonDown"
        MouseLeftButtonUp="Root_MouseLeftButtonUp"
        MouseMove="Root_MouseMove">

    <Grid>
        <!-- Pinned icon - Razer Green -->
        <Border x:Name="Pin"
            Width="52" Height="52"
            CornerRadius="26"
            Background="#FF429B00"
            BorderBrush="#55FFFFFF"
            BorderThickness="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <TextBlock Text="🔑"
                 Foreground="White"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" Cursor="Hand"/>
        </Border>

        <!-- Expanded bubbles -->
        <Canvas x:Name="BubblesHost" Visibility="Collapsed" IsHitTestVisible="True">
            <!-- Buttons created in code-behind -->
        </Canvas>

        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Edit snippets" Click="EditSnippets_Click"/>
                <Separator/>
                <MenuItem x:Name="TaskbarToggleMenuItem" Header="Hide from Taskbar" Click="ToggleTaskbar_Click"/>
                <MenuItem x:Name="PinToggleMenuItem" Header="Unpin the Bubble" Click="TogglePin_Click"/>
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </ContextMenu>
        </Grid.ContextMenu>
    </Grid>
</Window>
