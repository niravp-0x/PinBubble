<Window x:Class="PinBubble.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="64" Height="64"
        Icon="Assets/pin.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        Deactivated="Window_Deactivated"
        StateChanged="Window_StateChanged"
        MouseLeftButtonDown="Root_MouseLeftButtonDown"
        MouseLeftButtonUp="Root_MouseLeftButtonUp"
        MouseMove="Root_MouseMove">

    <Grid>
        <!-- Pinned icon - Razer Green -->
        <Border x:Name="Pin"
            Width="52" Height="52"
            CornerRadius="26"
            Background="#FF429B00"
            BorderBrush="#55FFFFFF"
            BorderThickness="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <TextBlock Text="🔑"
                 Foreground="White"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" Cursor="Hand"/>
        </Border>

        <!-- Translucent backing shown only in expanded mode -->
        <Border x:Name="ExpandedBackdrop"
            Visibility="Collapsed"
            Background="#7A101216"
            CornerRadius="16"
            Margin="8"
            BorderBrush="#55FFFFFF"
            BorderThickness="1"/>

        <!-- Expanded bubbles -->
        <Canvas x:Name="BubblesHost" Visibility="Collapsed" IsHitTestVisible="True">
            <!-- Buttons created in code-behind -->
        </Canvas>

        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Edit snippets" Click="EditSnippets_Click"/>
                <Separator/>
                <MenuItem x:Name="TaskbarToggleMenuItem" Header="Hide from Taskbar" Click="ToggleTaskbar_Click"/>
                <MenuItem x:Name="DarkThemeMenuItem" Header="Dark Theme" IsCheckable="True" IsChecked="True" Click="ToggleDarkTheme_Click"/>
                <MenuItem x:Name="PinToggleMenuItem" Header="Unpin the Bubble" Click="TogglePin_Click"/>
                <MenuItem Header="Backdrop Opacity">
                    <MenuItem x:Name="BackdropOpacity20MenuItem" Header="20%" Tag="0.20" IsCheckable="True" Click="BackdropOpacity_Click"/>
                    <MenuItem x:Name="BackdropOpacity35MenuItem" Header="35%" Tag="0.35" IsCheckable="True" Click="BackdropOpacity_Click"/>
                    <MenuItem x:Name="BackdropOpacity50MenuItem" Header="50%" Tag="0.50" IsCheckable="True" Click="BackdropOpacity_Click"/>
                    <MenuItem x:Name="BackdropOpacity65MenuItem" Header="65%" Tag="0.65" IsCheckable="True" Click="BackdropOpacity_Click"/>
                    <MenuItem x:Name="BackdropOpacity80MenuItem" Header="80%" Tag="0.80" IsCheckable="True" Click="BackdropOpacity_Click"/>
                </MenuItem>
                <MenuItem Header="Reset Preferences" Click="ResetPreferences_Click"/>
                <Separator/>
                <MenuItem Header="About" Click="About_Click"/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </ContextMenu>
        </Grid.ContextMenu>
    </Grid>
</Window>
