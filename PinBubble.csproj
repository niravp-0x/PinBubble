    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>Assets\pin.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <!-- <PackageReference Include="Microsoft.Windows.Compatibility" Version="8.2.0" /> -->
    <PackageReference Include="Microsoft.Windows.Compatibility" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\pin.ico" />
  </ItemGroup>
</Project>
